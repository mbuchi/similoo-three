{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/three3d/:op", "destination": "/api/three3d?path=:op" },
    { "source": "/splat", "destination": "/splat.html" }
  ]
}
